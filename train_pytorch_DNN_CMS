class TorchModelWrapper(BaseEstimator, ClassifierMixin):

    def __init__(self, model):
        self.model = model
        self.classes_ = np.array([0, 1])

    def fit(self, X, y):
        # Model zaten eğitildi
        return self

    def predict_proba(self, X):
        self.model.eval()

        with torch.no_grad():
            X_tensor = torch.tensor(
                X,
                dtype=torch.float32
            )

            logits = self.model(X_tensor)

            prob_signal = torch.sigmoid(logits).cpu().numpy().ravel()

        prob_background = 1 - prob_signal

        return np.column_stack(
            (prob_background, prob_signal)
        )

    def predict(self, X):
        proba = self.predict_proba(X)
        return np.argmax(proba, axis=1)

    def decision_function(self, X):
        self.model.eval()

        with torch.no_grad():
            X_tensor = torch.tensor(
                X,
                dtype=torch.float32
            )

            logits = self.model(X_tensor)

        return logits.cpu().numpy().ravel()


