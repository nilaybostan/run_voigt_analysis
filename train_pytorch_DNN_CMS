)

lossfn = nn.BCEWithLogitsLoss(reduction="none")
opt = torch.optim.Adam(model.parameters(), lr=LR)

# ============================================================
# TRAINING LOOP WITH EARLY STOPPING
# ============================================================
train_loss, val_loss = [], []
best_auc = 0.0
bad = 0

Xval_tensor = torch.tensor(Xval, dtype=torch.float32)
yval_tensor = torch.tensor(yval[:, None], dtype=torch.float32)
wval_tensor = torch.tensor(wtrain_val[:, None], dtype=torch.float32)

for epoch in range(EPOCHS):
    model.train()
    running = 0.0

    for xb, yb, wb in train_loader:
        p = model(xb)
        loss_per_event = lossfn(p, yb)
        loss = (loss_per_event * wb).sum() / (wb.sum().clamp_min(1e-12))

        opt.zero_grad()
        loss.backward()
        opt.step()
        running += loss.item()

    epoch_train_loss = running / len(train_loader)
    train_loss.append(epoch_train_loss)

    # Validation Evaluation
    model.eval()
    with torch.no_grad():
        logits = model(Xval_tensor)
        val_loss_events = lossfn(logits, yval_tensor)
        vl = (val_loss_events * wval_tensor).sum() / (wval_tensor.sum().clamp_min(1e-12))
        val_loss.append(vl.item())

        pv = torch.sigmoid(logits)
        aucv = roc_auc_score(yval, pv.numpy().ravel(), sample_weight=wtrain_val)

    print(f"Epoch {epoch + 1:3d} | Train loss = {epoch_train_loss:.6f} | Val loss = {vl.item():.6f} | Val AUC = {aucv:.6f}")

    if aucv > best_auc:
        best_auc = aucv
        bad = 0
        torch.save(model.state_dict(), "best_model.pth")
    else:
        bad += 1
        if bad >= PATIENCE:
            print("Early stopping triggered.")
            break

