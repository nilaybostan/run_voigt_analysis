import time

XRD_RETRIES = 4
XRD_TIMEOUT = 120
XRD_RETRY_SLEEP = 8

# Global redirector bazen timeout verebilir. Aynı /store/... dosyasını
# alternatif CMS redirector'ları üzerinden de deniyoruz.
XRD_REDIRECTORS = [
    "root://cms-xrd-global.cern.ch//",
    "root://xrootd-cms.infn.it//",
    "root://cmsxrootd.fnal.gov//",
]

def candidate_urls(url):
    """Return the original URL plus alternative redirectors for /store/... files."""
    out = [url]
    if "/store/" in url:
        store_path = "/store/" + url.split("/store/", 1)[1]
        for redirector in XRD_REDIRECTORS:
            alt_url = redirector + store_path.lstrip("/")
            if alt_url not in out:
                out.append(alt_url)
    return out


def read_tree_arrays(url, tree_name, branches, library):
    """Read one TTree with retries and redirector fallback."""
    last_error = None
    for candidate in candidate_urls(url):
        for trial in range(1, XRD_RETRIES + 1):
            try:
                with uproot.open(candidate, timeout=XRD_TIMEOUT) as root_file:
                    if tree_name not in root_file:
                        raise KeyError(f"Tree '{tree_name}' not found")
                    tree = root_file[tree_name]
                    return tree.arrays(branches, library=library), candidate
            except KeyboardInterrupt:
                raise
            except Exception as exc:
                last_error = exc
                print(
                    f"[{tree_name}] attempt {trial}/{XRD_RETRIES} failed via "
                    f"{candidate.split('//')[0]}//...: {type(exc).__name__}: {exc}"
                )
                if trial < XRD_RETRIES:
                    time.sleep(XRD_RETRY_SLEEP * trial)

    raise OSError(
        f"Could not read tree '{tree_name}' after all retries/redirectors. "
        f"Original file: {url}. Last error: {last_error}"
    )


def get_sum_genweight(files):
    """Return (sumGenWeight, usable_files).

    A file is accepted only if both Runs/genEventSumw and Events are reachable.
    This keeps the normalization consistent with the files actually processed.
    """
    total_sumw = 0.0
    usable_files = []
    failed_files = []

    for i, f in enumerate(files, 1):
        print(f"Checking file {i}/{len(files)} for Runs tree...")
        try:
            runs_arrays, working_url = read_tree_arrays(
                f, "Runs", ["genEventSumw"], library="np"
            )
            file_sumw = float(np.sum(runs_arrays["genEventSumw"]))

            # Quick Events reachability check before including this file in sumw.
            # Reading a tiny entry range is not consistently supported through all
            # uproot high-level paths, so opening and checking the tree is enough here.
            with uproot.open(working_url, timeout=XRD_TIMEOUT) as root_file:
                if "Events" not in root_file:
                    raise KeyError("Tree 'Events' not found")

            total_sumw += file_sumw
            usable_files.append(working_url)
        except KeyboardInterrupt:
            raise
        except Exception as exc:
            print(f"WARNING: skipping unreachable file:\n  {f}\n  {type(exc).__name__}: {exc}")
            failed_files.append(f)

    if not usable_files:
        raise RuntimeError("No usable ROOT files remain after XRootD checks.")
    if not np.isfinite(total_sumw) or total_sumw == 0.0:
        raise RuntimeError(f"Invalid total sumGenWeight: {total_sumw}")

    print(
        f"Usable files: {len(usable_files)}/{len(files)} | "
        f"Skipped: {len(failed_files)} | sumGenWeight = {total_sumw:.8e}"
    )
    return total_sumw, usable_files


# ============================================================
# LOAD ONE PROCESS
# ============================================================
def load_sample(files, label, process, xsec_pb):
    files = remove_duplicates(files)
    if len(files) == 0:
        raise RuntimeError(f"No files found for {process}")

    print(f"\n--- Loading {process} ---")
    sumw, usable_files = get_sum_genweight(files)
    normalization = xsec_pb * LUMI_PB / sumw

    arrays = []
    loaded_sumw = 0.0

    for i, f in enumerate(usable_files, 1):
        print(f"Reading Events {i}/{len(usable_files)}: {f}")
        try:
            arr, working_url = read_tree_arrays(f, "Events", BRANCHES, library="ak")

            # Re-read this file's sumw only after Events was successfully loaded.
            # Therefore a later Events failure cannot bias the normalization.
            runs_arrays, _ = read_tree_arrays(
                working_url, "Runs", ["genEventSumw"], library="np"
            )
            loaded_sumw += float(np.sum(runs_arrays["genEventSumw"]))
            arrays.append(arr)
        except KeyboardInterrupt:
            raise
        except Exception as exc:
            print(
                f"WARNING: Events could not be read; file skipped:\n"
                f"  {f}\n  {type(exc).__name__}: {exc}"
            )

    if len(arrays) == 0:
        raise RuntimeError(f"No ROOT files loaded for {process}")
    if not np.isfinite(loaded_sumw) or loaded_sumw == 0.0:
        raise RuntimeError(f"Invalid loaded sumGenWeight for {process}: {loaded_sumw}")

    # Important: normalize to the subset whose Events tree was actually loaded.
    normalization = xsec_pb * LUMI_PB / loaded_sumw
    t = ak.concatenate(arrays)

    gen_weight = ak.to_numpy(t.genWeight).astype(np.float64)
    w_physics = gen_weight * normalization

    mu1pt = alt(t.Muon_pt, 0, fill_val=0.0)
    mu2pt = alt(t.Muon_pt, 1, fill_val=0.0)
    mu1eta = alt(t.Muon_eta, 0, fill_val=0.0)
    mu2eta = alt(t.Muon_eta, 1, fill_val=0.0)
    mu1phi = alt(t.Muon_phi, 0, fill_val=0.0)
    mu2phi = alt(t.Muon_phi, 1, fill_val=0.0)
    mu1q = alt(t.Muon_charge, 0, fill_val=0)
    mu2q = alt(t.Muon_charge, 1, fill_val=0)

    j1pt = alt(t.Jet_pt, 0, fill_val=-999.0)
    j2pt = alt(t.Jet_pt, 1, fill_val=-999.0)
    j1eta = alt(t.Jet_eta, 0, fill_val=-999.0)
    j2eta = alt(t.Jet_eta, 1, fill_val=-999.0)
    j1phi = alt(t.Jet_phi, 0, fill_val=-999.0)
    j2phi = alt(t.Jet_phi, 1, fill_val=-999.0)

    mll_squared = 2 * mu1pt * mu2pt * (
        np.cosh(mu1eta - mu2eta) - np.cos(mu1phi - mu2phi)
    )
    mll = np.sqrt(np.maximum(0, mll_squared))

    valid_jj = (j1pt > 0) & (j2pt > 0)
    # Do not evaluate cosh(-999 - eta): compute only for valid two-jet events.
    n_events = len(t)
    mjj = np.full(n_events, -999.0, dtype=np.float64)
    dEta_jj = np.full(n_events, -999.0, dtype=np.float64)
    valid_jj_np = ak.to_numpy(valid_jj)
    if np.any(valid_jj_np):
        j1pt_np = ak.to_numpy(j1pt)
        j2pt_np = ak.to_numpy(j2pt)
        j1eta_np = ak.to_numpy(j1eta)
        j2eta_np = ak.to_numpy(j2eta)
        j1phi_np = ak.to_numpy(j1phi)
        j2phi_np = ak.to_numpy(j2phi)
        deta = j1eta_np[valid_jj_np] - j2eta_np[valid_jj_np]
        dphi = j1phi_np[valid_jj_np] - j2phi_np[valid_jj_np]
        mjj2 = 2 * j1pt_np[valid_jj_np] * j2pt_np[valid_jj_np] * (
            np.cosh(deta) - np.cos(dphi)
        )
        mjj[valid_jj_np] = np.sqrt(np.maximum(0.0, mjj2))
        dEta_jj[valid_jj_np] = np.abs(deta)

    dphi_mumu = np.arccos(np.clip(np.cos(mu1phi - mu2phi), -1.0, 1.0))
    dR = np.sqrt((mu1eta - mu2eta) ** 2 + dphi_mumu ** 2)

    mask = (
        (t.nMuon >= 2)
        & (t.nElectron == 0)
        & (mu1q != mu2q)
        & (mu1pt > 26)
        & (mu2pt > 20)
        & (abs(mu1eta) < 2.4)
        & (abs(mu2eta) < 2.4)
        & (mll > 110)
        & (mll < 150)
    )
    mask_np = ak.to_numpy(mask)

    met_pt = ak.to_numpy(t.PuppiMET_pt)
    met_phi = ak.to_numpy(t.PuppiMET_phi)

    X = np.column_stack([
        ak.to_numpy(mu1pt),
        ak.to_numpy(mu2pt),
        ak.to_numpy(mu1eta),
        ak.to_numpy(mu2eta),
        ak.to_numpy(dR),
        met_pt,
        np.sin(met_phi),
        np.cos(met_phi),
        ak.to_numpy(j1pt),
        ak.to_numpy(j2pt),
        dEta_jj,
        mjj,
        ak.to_numpy(t.nJet),
    ])

    X = X[mask_np]
    w_physics = w_physics[mask_np]

    finite_mask = np.isfinite(X).all(axis=1) & np.isfinite(w_physics)
    if not np.all(finite_mask):
        print(f"WARNING: removing {np.sum(~finite_mask)} non-finite selected events")
        X = X[finite_mask]
        w_physics = w_physics[finite_mask]

    y = np.full(len(X), label, dtype=np.int64)
    proc = np.full(len(X), process, dtype=object)

    print(
        f"{process}: {len(X)} selected events | "
        f"expected yield = {np.sum(w_physics):.6f}"
    )
    return X, y, w_physics, proc

