def calculate_significance(y_true, y_probs, weights, threshold):
    # Sinyal (S) ve Arka Plan (B) ağırlıklı toplamları
    s = np.sum(weights[(y_true == 1) & (y_probs > threshold)])
    b = np.sum(weights[(y_true == 0) & (y_probs > threshold)])
    return s / np.sqrt(s + b + 1e-9)

