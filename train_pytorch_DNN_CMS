# DÜZELTME: SINIF DENGESİZLİĞİ İÇİN AĞIRLIK NORMALİZASYONU (Class Balancing)
# ============================================================
def get_balanced_weights(y_arr, w_phys):
    w_train = np.abs(w_phys).copy()
    sig_mask = (y_arr == 1)
    bkg_mask = (y_arr == 0)
    
    # Sinyal ve Arka Plan toplam ağırlık payları birbirine eşitleniyor
    w_train[sig_mask] = w_train[sig_mask] / np.sum(w_train[sig_mask])
    w_train[bkg_mask] = w_train[bkg_mask] / np.sum(w_train[bkg_mask])
    return w_train

wtrain_tr = get_balanced_weights(ytr, wphys_tr)
