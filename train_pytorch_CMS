def load_sample(files, label, process, xsec_pb):
    files = remove_duplicates(files)
    if len(files) == 0:
        raise RuntimeError(f"No files found for {process}")

    sumw = get_sum_genweight(files)
    normalization = xsec_pb * LUMI_PB / sumw

    arrays = []
    for f in files:
        try:
            arr = uproot.open(f + ":Events").arrays(BRANCHES, library="ak")
            arrays.append(arr)
        except Exception as e:
            print(f"Failed to read Events tree for: {f}, error: {e}")

    if len(arrays) == 0:
        raise RuntimeError(f"No ROOT files loaded for {process}")

    t = ak.concatenate(arrays)

    gen_weight = ak.to_numpy(t.genWeight).astype(np.float64)
    w_physics = gen_weight * normalization

    # Muonlar her zaman var (Seçim kriteri en az 2 muon gerektiriyor)
    mu1pt = alt(t.Muon_pt, 0, fill_val=0.0)
    mu2pt = alt(t.Muon_pt, 1, fill_val=0.0)
    mu1eta = alt(t.Muon_eta, 0, fill_val=0.0)
    mu2eta = alt(t.Muon_eta, 1, fill_val=0.0)
    mu1phi = alt(t.Muon_phi, 0, fill_val=0.0)
    mu2phi = alt(t.Muon_phi, 1, fill_val=0.0)
    mu1q = alt(t.Muon_charge, 0, fill_val=0)
    mu2q = alt(t.Muon_charge, 1, fill_val=0)

    # DÜZELTME: Jetler için boş değer dolgusu -999.0 yapıldı.
    j1pt = alt(t.Jet_pt, 0, fill_val=-999.0)
    j2pt = alt(t.Jet_pt, 1, fill_val=-999.0)
    j1eta = alt(t.Jet_eta, 0, fill_val=-999.0)
    j2eta = alt(t.Jet_eta, 1, fill_val=-999.0)
    j1phi = alt(t.Jet_phi, 0, fill_val=-999.0)
    j2phi = alt(t.Jet_phi, 1, fill_val=-999.0)

    mll_squared = 2 * mu1pt * mu2pt * (np.cosh(mu1eta - mu2eta) - np.cos(mu1phi - mu2phi))
    mll = np.sqrt(np.maximum(0, mll_squared))

    # Jet yoksa mjj hesabı maskelenmeli/korunmalı
    mjj_squared = 2 * j1pt * j2pt * (np.cosh(j1eta - j2eta) - np.cos(j1phi - j2phi))
    mjj = np.where((j1pt > 0) & (j2pt > 0), np.sqrt(np.maximum(0, mjj_squared)), -999.0)
    dEta_jj = np.where((j1pt > 0) & (j2pt > 0), abs(j1eta - j2eta), -999.0)

    dphi_mumu = np.arccos(np.cos(mu1phi - mu2phi))
    dR = np.sqrt((mu1eta - mu2eta) ** 2 + dphi_mumu ** 2)

    mask = (
        (t.nMuon >= 2)
        & (t.nElectron == 0)
        & (mu1q != mu2q)
        & (mu1pt > 26)
        & (mu2pt > 15)
        & (abs(mu1eta) < 2.4)
        & (abs(mu2eta) < 2.4)
        & (mll > 110)
        & (mll < 150)
    )
    mask_np = ak.to_numpy(mask)

    # MET periyodik bileşenleri hesaplanıyor
    met_pt = ak.to_numpy(t.PuppiMET_pt)
    met_phi = ak.to_numpy(t.PuppiMET_phi)
    sin_met_phi = np.sin(met_phi)
    cos_met_phi = np.cos(met_phi)

    # DÜZELTME: "mll" bu tablodan kaldırıldı. Açısal ve jet düzeltmeleri yansıtıldı.
    X = np.column_stack([
        ak.to_numpy(mu1pt),
        ak.to_numpy(mu2pt),
        ak.to_numpy(mu1eta),
        ak.to_numpy(mu2eta),
        ak.to_numpy(dR),
        met_pt,
        sin_met_phi,
        cos_met_phi,
        ak.to_numpy(j1pt),
        ak.to_numpy(j2pt),
        dEta_jj,
        mjj,
        ak.to_numpy(t.nJet),
    ])

    X = X[mask_np]
    w_physics = w_physics[mask_np]
    y = np.full(len(X), label, dtype=np.int64)
    proc = np.full(len(X), process, dtype=object)

    print(f"{process}: {len(X)} selected events | expected yield = {np.sum(w_physics):.6f}")
    return X, y, w_physics, proc

# ============================================================
# LOAD AND MERGE ALL PROCESSES
# ============================================================
all_X, all_y, all_w_physics, all_proc = [], [], [], []

for process, cfg in SAMPLES.items():
    X_i, y_i, wphys_i, proc_i = load_sample(cfg["files"], cfg["label"], process, XSECS_PB[process])
    all_X.append(X_i)
    all_y.append(y_i)
    all_w_physics.append(wphys_i)
    all_proc.append(proc_i)

X = np.vstack(all_X)
y = np.concatenate(all_y)
w_physics = np.concatenate(all_w_physics)
proc = np.concatenate(all_proc)

# ============================================================
# TRAIN / VALIDATION / TEST SPLIT (60% / 20% / 20%)
# ============================================================
Xtr, Xtmp, ytr, ytmp, wphys_tr, wphys_tmp, proc_tr, proc_tmp = train_test_split(
    X, y, w_physics, proc, test_size=0.4, stratify=y, random_state=42
)
Xval, Xte, yval, yte, wphys_val, wphys_te, proc_val, proc_te = train_test_split(
    Xtmp, ytmp, wphys_tmp, proc_tmp, test_size=0.5, stratify=ytmp, random_state=42
)

# ============================================================
# DÜZELTME: SINIF DENGESİZLİĞİ İÇİN AĞIRLIK NORMALİZASYONU (Class Balancing)
# ============================================================
def get_balanced_weights(y_arr, w_phys):
    w_train = np.abs(w_phys).copy()
    sig_mask = (y_arr == 1)
    bkg_mask = (y_arr == 0)
    
    # Sinyal ve Arka Plan toplam ağırlık payları birbirine eşitleniyor
    w_train[sig_mask] = w_train[sig_mask] / np.sum(w_train[sig_mask])
    w_train[bkg_mask] = w_train[bkg_mask] / np.sum(w_train[bkg_mask])
    return w_train

wtrain_tr = get_balanced_weights(ytr, wphys_tr)
wtrain_val = get_balanced_weights(yval, wphys_val)
wtrain_te = get_balanced_weights(yte, wphys_te)

# ============================================================
# STANDARDIZATION
# ============================================================
sc = StandardScaler()
Xtr = sc.fit_transform(Xtr)
Xval = sc.transform(Xval)
Xte = sc.transform(Xte)

# ============================================================
# PYTORCH DATA LOADER
# ============================================================
train_loader = DataLoader(
    TensorDataset(
        torch.tensor(Xtr, dtype=torch.float32),
        torch.tensor(ytr[:, None], dtype=torch.float32),
        torch.tensor(wtrain_tr[:, None], dtype=torch.float32)
    ),
    batch_size=BATCH_SIZE,
    shuffle=True
)

# ============================================================
# MODEL DESIGN 
# ============================================================
model = nn.Sequential(
    nn.Linear(13, 225),
    nn.ReLU(),
    nn.Dropout(0.1),
    nn.Linear(225, 100),
    nn.ReLU(),
    nn.Dropout(0.1),
    nn.Linear(100, 64),
    nn.ReLU(),
    nn.Dropout(0.1),
    nn.Linear(64, 1),
)

lossfn = nn.BCEWithLogitsLoss(reduction="none")
opt = torch.optim.Adam(model.parameters(), lr=LR)

# ============================================================
# TRAINING LOOP WITH EARLY STOPPING
# ============================================================
train_loss, val_loss = [], []
best_auc = 0.0
bad = 0

Xval_tensor = torch.tensor(Xval, dtype=torch.float32)
yval_tensor = torch.tensor(yval[:, None], dtype=torch.float32)
wval_tensor = torch.tensor(wtrain_val[:, None], dtype=torch.float32)

for epoch in range(EPOCHS):
    model.train()
    running = 0.0

    for xb, yb, wb in train_loader:
        p = model(xb)
        loss_per_event = lossfn(p, yb)
        loss = (loss_per_event * wb).sum() / (wb.sum().clamp_min(1e-12))

        opt.zero_grad()
        loss.backward()
        opt.step()
        running += loss.item()

    epoch_train_loss = running / len(train_loader)
    train_loss.append(epoch_train_loss)

    # Validation Evaluation
    model.eval()
    with torch.no_grad():
        logits = model(Xval_tensor)
        val_loss_events = lossfn(logits, yval_tensor)
        vl = (val_loss_events * wval_tensor).sum() / (wval_tensor.sum().clamp_min(1e-12))
        val_loss.append(vl.item())

        pv = torch.sigmoid(logits)
        aucv = roc_auc_score(yval, pv.numpy().ravel(), sample_weight=wtrain_val)

    print(f"Epoch {epoch + 1:3d} | Train loss = {epoch_train_loss:.6f} | Val loss = {vl.item():.6f} | Val AUC = {aucv:.6f}")

    if aucv > best_auc:
        best_auc = aucv
        bad = 0
        torch.save(model.state_dict(), "best_model.pth")
    else:
        bad += 1
        if bad >= PATIENCE:
            print("Early stopping triggered.")
            break

# ============================================================
# EVALUATION & METRICS GENERATION
# ============================================================
model.load_state_dict(torch.load("best_model.pth", map_location="cpu"))
model.eval()

with torch.no_grad():
    ptr = torch.sigmoid(model(torch.tensor(Xtr, dtype=torch.float32))).numpy().ravel()
    pval = torch.sigmoid(model(torch.tensor(Xval, dtype=torch.float32))).numpy().ravel()
    pte = torch.sigmoid(model(torch.tensor(Xte, dtype=torch.float32))).numpy().ravel()

# ROC Eğrisi ve Dinamik Threshold (Eşik Değeri) Hesabı
fpr, tpr, thresholds = roc_curve(yte, pte, sample_weight=wtrain_te)
best_idx = np.argmax(tpr - fpr)
opt_threshold = thresholds[best_idx]
print(f"\nCalculated Optimal Threshold from ROC = {opt_threshold:.4f}")


pred = (pte > opt_threshold).astype(int)

print("\n==============================")
print("FINAL PERFORMANCE METRICS")
print("==============================")
