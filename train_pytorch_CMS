# ============================================================
# CALCULATE sumGenWeight
# ============================================================
def get_sum_genweight(files):
    total_sumw = 0.0
    for f in files:
        try:
            runs = uproot.open(f + ":Runs")
            values = runs["genEventSumw"].array(library="np")
            file_sumw = np.sum(values)
            total_sumw += file_sumw
        except Exception as e:
            print(f"Failed to read Runs tree for: {f}, error: {e}")
    if total_sumw == 0:
        raise RuntimeError("Total sumGenWeight is zero!")
    return total_sumw

